{
  "Id": "8a897ad8-5108-4a92-ad32-31d6b9ada803",
  "Title": "\u0414\u0440\u0443\u0433\u043E\u0435",
  "Description": "\u041F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u044C\u0442\u0435 \u0441\u0435\u0431\u0435 \u043C\u0438\u0440, \u0433\u0434\u0435 \u0430\u0434\u0440\u0435\u043D\u0430\u043B\u0438\u043D \u0431\u0443\u0440\u043B\u0438\u0442 \u0432 \u0432\u0435\u043D\u0430\u0445, \u0430 \u043A\u0430\u0436\u0434\u044B\u0439 \u0448\u0430\u0433 \u043D\u0430\u043F\u043E\u043B\u043D\u0435\u043D \u043E\u0436\u0438\u0434\u0430\u043D\u0438\u0435\u043C! \u0414\u043E\u0431\u0440\u043E \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u0442\u044C \u0432 \u0437\u0430\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u044E\u0449\u0438\u0439 \u043C\u0438\u0440 \u0441\u043F\u043E\u0440\u0442\u0438\u0432\u043D\u044B\u0445 \u0438\u0433\u0440, \u043D\u0430\u043F\u043E\u043B\u043D\u0435\u043D\u043D\u044B\u0445 \u0434\u0443\u0445\u043E\u043C \u043F\u0440\u0438\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0439, \u0441\u043E\u0441\u0442\u044F\u0437\u0430\u043D\u0438\u0439 \u0438 \u043F\u043E\u0431\u0435\u0434! \u042D\u0442\u043E \u043C\u0435\u0441\u0442\u043E, \u0433\u0434\u0435 \u0432\u0430\u0448\u0430 \u0434\u0440\u0443\u0436\u0431\u0430 \u043A\u0440\u0435\u043F\u043D\u0435\u0442 \u0432 \u0441\u043F\u043B\u043E\u0447\u0435\u043D\u043D\u044B\u0445 \u043A\u043E\u043C\u0430\u043D\u0434\u043D\u044B\u0445 \u0438\u0433\u0440\u0430\u0445, \u0430 \u0441\u043C\u0435\u0445 \u0438 \u0440\u0430\u0434\u043E\u0441\u0442\u044C \u0441\u043E\u043F\u0440\u043E\u0432\u043E\u0436\u0434\u0430\u044E\u0442 \u043A\u0430\u0436\u0434\u044B\u0439 \u0443\u0441\u043F\u0435\u0445. \u041F\u0440\u0438\u0433\u043E\u0442\u043E\u0432\u044C\u0442\u0435\u0441\u044C \u043A \u043D\u0435\u0437\u0430\u0431\u044B\u0432\u0430\u0435\u043C\u044B\u043C \u043F\u0440\u0438\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u044F\u043C \u0432 \u0441\u043F\u043E\u0440\u0442\u0438\u0432\u043D\u043E\u043C \u043A\u043B\u0443\u0431\u0435! \u0412 \u043D\u0430\u0448\u0435\u043C \u043A\u043B\u0443\u0431\u0435 \u0432\u044B \u0441\u043C\u043E\u0436\u0435\u0442\u0435 \u043F\u043E\u043F\u0440\u043E\u0431\u043E\u0432\u0430\u0442\u044C \u0441\u0435\u0431\u044F \u0432 \u0440\u0430\u0437\u043D\u044B\u0445 \u0432\u0438\u0434\u0430\u0445 \u0441\u043F\u043E\u0440\u0442\u0430, \u0430 \u0442\u0430\u043A\u0436\u0435 \u043F\u043E\u0433\u0440\u0443\u0437\u0438\u0442\u044C\u0441\u044F \u0432 \u043C\u0438\u0440 \u0438\u0433\u0440, \u0433\u0434\u0435 \u0432\u0430\u043C \u043F\u0440\u0435\u0434\u0441\u0442\u043E\u0438\u0442 \u043F\u0440\u043E\u044F\u0432\u0438\u0442\u044C \u0432\u0441\u0435 \u0441\u0432\u043E\u0438 \u043B\u0438\u0434\u0435\u0440\u0441\u043A\u0438\u0435 \u043A\u0430\u0447\u0435\u0441\u0442\u0432\u0430 \u0438 \u043D\u0430\u0432\u044B\u043A\u0438. \u0412\u044B\u0437\u043E\u0432 \u043F\u0440\u0438\u043D\u044F\u0442 - \u044D\u0442\u043E \u043C\u0435\u0441\u0442\u043E, \u0433\u0434\u0435 \u043A\u0430\u0436\u0434\u044B\u0439 \u043C\u043E\u0436\u0435\u0442 \u0441\u0442\u0430\u0442\u044C \u0433\u0435\u0440\u043E\u0435\u043C! \u041F\u0440\u0438\u0441\u043E\u0435\u0434\u0438\u043D\u044F\u0439\u0442\u0435\u0441\u044C \u043A \u043D\u0430\u043C \u0438 \u043D\u0430\u0447\u043D\u0438\u0442\u0435 \u0441\u0432\u043E\u0435 \u043F\u0440\u0438\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435 \u0441\u0435\u0433\u043E\u0434\u043D\u044F!",
  "Teacher": "\u0421\u0435\u0440\u0433\u0435\u0435\u0432 \u0410\u043D\u0434\u0440\u0435\u0439",
  "AgeGroup": "4 \u0433\u043E\u0434\u0430 - 30 \u043B\u0435\u0442",
  "LearnSkills": "\u0424\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0430\u044F \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043A\u0430\n\n\u041F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043A\u0430 \u043A \u0441\u043E\u0440\u0435\u0432\u043D\u043E\u0432\u0430\u043D\u0438\u044F\u043C\n\n\u041A\u043E\u043C\u0430\u043D\u0434\u043D\u0430\u044F \u0438\u0433\u0440\u0430, \u0443\u043C\u0435\u043D\u0438\u0435 \u0434\u0435\u0439\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C \u0432 \u043A\u043E\u043B\u043B\u0435\u043A\u0442\u0438\u0432\u0435\n\n\u0412\u0441\u0435\u0441\u0442\u043E\u0440\u043E\u043D\u043D\u0435\u0435 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u0438",

{
  "Id": "a8dc5249-215e-4634-8ac2-0b8ea0744ec6",
  "Title": "\u0420\u0430\u0431\u043E\u0442\u0430 \u043F\u043E \u0434\u0435\u0440\u0435\u0432\u0443",
  "Description": "\u0421\u0442\u0443\u0434\u0438\u0438 \u0441\u0442\u043E\u043B\u044F\u0440\u043D\u043E\u0433\u043E \u043C\u0430\u0441\u0442\u0435\u0440\u0441\u0442\u0432\u0430 \u0022\u0421\u0442\u043E\u043B\u044F\u0440\u043A\u0430\u0022 \u0438 \u0022Wood \u043C\u0430\u0441\u0442\u0435\u0440\u0022 \u043D\u0430\u0447\u0430\u043B\u0438 \u0441\u0432\u043E\u044E \u0440\u0430\u0431\u043E\u0442\u0443 \u0432 2021 \u0433\u043E\u0434\u0443. \u0420\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u044C \u0427\u0435\u0440\u043A\u0430\u0441\u043E\u0432 \u041E\u043B\u0435\u0433 \u0411\u043E\u0440\u0438\u0441\u043E\u0432\u0438\u0447 \u043F\u043E\u043C\u043E\u0433\u0430\u0435\u0442 \u0434\u0435\u0442\u044F\u043C \u043F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u0442\u044C\u0441\u044F \u0441 \u0442\u0430\u043A\u0438\u043C \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u043E\u043C \u0434\u043B\u044F \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u0442\u0432\u0430, \u043A\u0430\u043A \u0434\u0435\u0440\u0435\u0432\u043E \u0438 \u0434\u0435\u0440\u0435\u0432\u044F\u043D\u043D\u044B\u0435 \u0437\u0430\u0433\u043E\u0442\u043E\u0432\u043A\u0438.\u2028\u2028\u0417\u0430\u043D\u044F\u0442\u0438\u044F \u0432 \u0441\u0442\u0443\u0434\u0438\u044F\u0445 \u0432\u0441\u0435\u0433\u0434\u0430 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u044B\u0435 \u0438 \u0443\u0432\u043B\u0435\u043A\u0430\u0442\u0435\u043B\u044C\u043D\u044B\u0435, \u0434\u0435\u0442\u0438 \u0434\u0435\u043B\u0430\u044E\u0442 \u043C\u043E\u0434\u0435\u043B\u0438 \u0432\u043E\u0435\u043D\u043D\u043E\u0439 \u0438 \u0433\u0440\u0430\u0436\u0434\u0430\u043D\u0441\u043A\u043E\u0439 \u0442\u0435\u0445\u043D\u0438\u043A\u0438, \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u044B \u0438\u043D\u0442\u0435\u0440\u044C\u0435\u0440\u0430, \u0443\u0447\u0430\u0441\u0442\u0432\u0443\u044E\u0442 \u0432 \u0432\u044B\u0441\u0442\u0430\u0432\u043A\u0430\u0445 \u0438 \u043C\u0430\u0441\u0442\u0435\u0440-\u043A\u043B\u0430\u0441\u0441\u0430\u0445.\u2028\u2028\u0412 \u043F\u0435\u0440\u0432\u044B\u0439 \u0433\u043E\u0434 \u0440\u0430\u0431\u043E\u0442\u044B \u0432 \u0441\u0442\u0443\u0434\u0438\u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u043B\u0438\u0441\u044C \u043C\u0430\u043B\u044C\u0447\u0438\u043A\u0438 \u043E\u0442 5 \u0434\u043E 14 \u043B\u0435\u0442. \u041D\u043E \u0443\u0436\u0435 \u0441\u043E \u0432\u0442\u043E\u0440\u043E\u0433\u043E \u0433\u043E\u0434\u0430 \u0440\u0430\u0431\u043E\u0442\u044B \u043A \u0437\u0430\u043D\u044F\u0442\u0438\u044F\u043C \u043F\u0440\u0438\u0441\u043E\u0435\u0434\u0438\u043D\u0438\u043B\u0438\u0441\u044C \u0438 \u0434\u0435\u0432\u043E\u0447\u043A\u0438. \u0414\u0435\u0442\u0438 \u043E\u0441\u0432\u0430\u0438\u0432\u0430\u044E\u0442 \u0443\u043C\u0435\u043D\u0438\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u0430\u043C\u0438: \u043C\u043E\u043B\u043E\u0442\u043A\u043E\u043C, \u043B\u043E\u0431\u0437\u0438\u043A\u043E\u043C, \u043F\u0438\u043B\u043E\u0439, \u043D\u0430\u0436\u0434\u0430\u0447\u043D\u043E\u0439 \u0431\u0443\u043C\u0430\u0433\u043E\u0439, \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u044F \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u044B\u0435 \u043F\u043E\u0434\u0435\u043B\u043A\u0438 \u0438 \u043F\u043E\u0434\u0430\u0440\u043A\u0438 \u0443 \u043F\u0440\u0430\u0437\u0434\u043D\u0438\u043A\u0430\u043C.",
  "Teacher": "\u0427\u0435\u0440\u043A\u0430\u0441\u043E\u0432 \u041E\u043B\u0435\u0433",
  "AgeGroup": "5 \u043B\u0435\u0442 - 14 \u043B\u0435\u0442",
  "LearnSkills": "\u0414\u0435\u0440\u0436\u0430\u0442\u044C \u0432 \u0440\u0443\u043A\u0430\u0445 \u0438 \u043F\u0440\u0438\u043C\u0435\u043D\u044F\u0442\u044C \u043C\u043D\u043E\u0433\u0438\u0435 \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442\u044B: \u0440\u0430\u0437\u043B\u0438\u0447\u043D\u044B\u0435 \u043D\u043E\u0436\u043E\u0432\u043A\u0438, \u043C\u043E\u043B\u043E\u0442\u043A\u0438, \u0441\u0442\u0440\u0443\u0431\u0446\u0438\u043D\u044B, \u043F\u043B\u043E\u0441\u043A\u043E\u0433\u0443\u0431\u0446\u044B.\n\n\u041F\u0440\u0438\u043C\u0435\u043D\u0435\u043D\u0438\u0435 \u0438 \u0441\u043E\u0447\u0435\u0442\u0430\u043D\u0438\u0435 \u0432 \u0438\u0437\u0434\u0435\u043B\u0438\u044F \u0438\u0437 \u0434\u0435\u0440\u0435\u0432\u0430 \u0434\u0440\u0443\u0433\u0438\u0445 \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u043E\u0432: \u0431\u0443\u043C\u0430\u0433\u0430 \u043D\u0438\u0442\u043A\u0438 \u0438 \u0434\u0440\n\n\u041E\u0432\u043B\u0430\u0434\u0435\u0435\u0442\u0435 \u043F\u0440\u043E\u0441\u0442\u044B\u043C\u0438 \u043F\u0440\u0438\u0451\u043C\u0430\u043C\u0438 \u0437\u0430\u0431\u0438\u0432\u0430\u043D\u0438\u044F \u0433\u0432\u043E\u0437\u0434\u0435\u0439\n\n\u041F\u0440\u0438\u0435\u043C\u0430\u043C \u0448\u043B\u0438\u0444\u043E\u0432\u043A\u0438.",

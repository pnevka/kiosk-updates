{
  "Id": "a68daf39-3f8a-4d6f-9d25-78bb61584285",
  "Title": "\u0418\u0437\u043E\u0431\u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E",
  "Description": "\u0428\u043A\u043E\u043B\u0430 \u0446\u0438\u0440\u043A\u043E\u0432\u043E\u0433\u043E \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0430 \u0022\u041D\u0430 \u0432\u044B\u0441\u043E\u0442\u0435\u0022 \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442 \u043F\u043E\u0434 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C \u0421\u043F\u0438\u0440\u0438\u0434\u043E\u043D\u043E\u0432\u0430 \u0413\u0435\u043D\u043D\u0430\u0434\u0438\u044F \u0412\u0430\u0441\u0438\u043B\u044C\u0435\u0432\u0438\u0447\u0430 - \u0430\u0440\u0442\u0438\u0441\u0442\u0430 \u0426\u0438\u0440\u043A\u0430 \u043D\u0430 \u043F\u0440\u043E\u0441\u043F\u0435\u043A\u0442\u0435 \u0412\u0435\u0440\u043D\u0430\u0434\u0441\u043A\u043E\u0433\u043E (\u0433. \u041C\u043E\u0441\u043A\u0432\u0430) \u0441 30-\u043B\u0435\u0442\u043D\u0438\u043C \u0441\u0442\u0430\u0436\u0435\u043C.\u2028\u2028\u0412 \u043F\u0440\u043E\u0433\u0440\u0430\u043C\u043C\u0443 \u043E\u0431\u0443\u0447\u0435\u043D\u0438\u044F \u0432\u0445\u043E\u0434\u044F\u0442 \u0430\u043A\u0440\u043E\u0431\u0430\u0442\u0438\u043A\u0430, \u044D\u043A\u0432\u0438\u043B\u0438\u0431\u0440\u0438\u0441\u0442\u0438\u043A\u0430, \u0432\u043E\u0437\u0434\u0443\u0448\u043D\u0430\u044F \u0433\u0438\u043C\u043D\u0430\u0441\u0442\u0438\u043A\u0430, \u0436\u043E\u043D\u0433\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435, \u0440\u0430\u0431\u043E\u0442\u0430 \u0441 \u0445\u0443\u043B\u0430-\u0445\u0443\u043F\u0430\u043C\u0438, \u0442\u0440\u044E\u043A\u043E\u0432\u044B\u0435 \u043D\u043E\u043C\u0435\u0440\u0430.\u2028\u2028\u0412 \u0441\u0442\u0443\u0434\u0438\u0438 \u0437\u0430\u043D\u0438\u043C\u0430\u044E\u0442\u0441\u044F \u0434\u0435\u0442\u0438 \u043E\u0442 6 \u043B\u0435\u0442 \u0438 \u0441\u0442\u0430\u0440\u0448\u0435. \u041D\u0430 \u0437\u0430\u043D\u044F\u0442\u0438\u044F\u0445 \u0441\u0442\u0443\u0434\u0438\u0438 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u0439 \u0446\u0438\u0440\u043A\u043E\u0432\u043E\u0439 \u0440\u0435\u043A\u0432\u0438\u0437\u0438\u0442.\u2028\u2028\u0423\u0447\u0430\u0441\u0442\u043D\u0438\u043A\u0438 \u0441\u0442\u0443\u0434\u0438\u0438 \u0432\u044B\u0441\u0442\u0443\u043F\u0430\u044E\u0442 \u043D\u0430 \u043A\u043E\u043D\u0446\u0435\u0440\u0442\u0430\u0445 \u0441 \u044F\u0440\u043A\u0438\u043C\u0438 \u0438 \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u043C\u0438 \u0446\u0438\u0440\u043A\u043E\u0432\u044B\u043C\u0438 \u043D\u043E\u043C\u0435\u0440\u0430\u043C\u0438.",
  "Teacher": "\u041B\u0430\u0442\u044B\u043D\u0446\u0435\u0432\u0430 \u041B\u044E\u0434\u043C\u0438\u043B\u0430",
  "AgeGroup": "6\u002B",
  "LearnSkills": "\u0420\u0430\u0437\u0432\u0438\u0442\u044C \u0432\u043E\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0435\n\n\u0423\u0441\u0438\u0434\u0447\u0438\u0432\u043E\u0441\u0442\u044C\n\n\u041F\u043B\u0430\u043D\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435 \u0436\u0435\u043B\u0430\u0435\u043C\u043E\u0433\u043E \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0430\n\n\u0410\u043D\u0430\u043B\u0438\u0437 \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u043D\u043E\u0433\u043E \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442\u0430",

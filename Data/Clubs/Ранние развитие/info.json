{
  "Id": "3f6a0c8d-808f-40cc-886c-c88f6fa24b15",
  "Title": "\u0420\u0430\u043D\u043D\u0438\u0435 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435",
  "Description": "\u0421\u0442\u0443\u0434\u0438\u044F \u0440\u0430\u043D\u043D\u0435\u0433\u043E \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u043A\u043E\u0433\u043E \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044F \u0022\u0410\u0439 \u0434\u0430 \u044F\u0022 \u043E\u0442\u043A\u0440\u044B\u043B\u0430\u0441\u044C \u0432 2023 \u0433\u043E\u0434\u0443. \u0420\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u044C \u0441\u0442\u0443\u0434\u0438\u0438 \u041B\u0435\u0432\u0447\u0443\u043A \u0412\u0430\u043B\u0435\u043D\u0442\u0438\u043D\u0430 \u041D\u0438\u043A\u043E\u043B\u0430\u0435\u0432\u043D\u0430 \u0438\u043C\u0435\u0435\u0442 \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0435 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435.\u2028\u2028\u041E\u043D\u0430 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442 \u0440\u0430\u0437\u043D\u043E\u043E\u0431\u0440\u0430\u0437\u043D\u044B\u0435 \u043C\u0435\u0442\u043E\u0434\u0438\u043A\u0438, \u043F\u0440\u0438\u043D\u0446\u0438\u043F\u044B \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u043B\u0435\u0433\u043B\u0438 \u0432 \u043E\u0441\u043D\u043E\u0432\u0443 \u0437\u0430\u043D\u044F\u0442\u0438\u0439 \u0432 \u0441\u0442\u0443\u0434\u0438\u0438 \u0440\u0430\u043D\u043D\u0435\u0433\u043E \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u043A\u043E\u0433\u043E \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044F \u0022\u0410\u0439 \u0434\u0430 \u044F!\u0022\u2028\u2028\u0412 \u0441\u0442\u0443\u0434\u0438\u0438 \u043D\u0435 \u0443\u0447\u0430\u0442 \u0434\u0435\u0442\u0435\u0439 \u0443\u0447\u0438\u0442\u044C\u0441\u044F, \u0430 \u0440\u0430\u0431\u043E\u0442\u0430\u044E\u0442 \u043D\u0430\u0434 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435\u043C \u041F\u041E\u0417\u041D\u0410\u0412\u0410\u0422\u0415\u041B\u042C\u041D\u041E\u0419 \u0421\u0424\u0415\u0420\u042B, \u0430 \u044D\u0442\u043E: \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u0435 \u0438 \u043E\u0449\u0443\u0449\u0435\u043D\u0438\u0435, \u0432\u043E\u0441\u043F\u0440\u0438\u044F\u0442\u0438\u0435 \u0438 \u043F\u0430\u043C\u044F\u0442\u044C, \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0435 \u0438 \u043C\u044B\u0448\u043B\u0435\u043D\u0438\u0435, \u0440\u0435\u0447\u044C \u0438 \u0432\u043E\u043E\u0431\u0440\u0430\u0436\u0435\u043D\u0438\u0435.\u2028\u2028\u0412 \u043C\u0438\u043D\u0438-\u0433\u0440\u0443\u043F\u043F\u0430\u0445 \u0437\u0430\u043D\u0438\u043C\u0430\u0435\u0442\u0441\u044F \u043D\u0435 \u0431\u043E\u043B\u0435\u0435 4-\u0445 \u0434\u0435\u0442\u0435\u0439, \u0447\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442 \u0443\u0434\u0435\u043B\u0438\u0442\u044C \u043A\u0430\u0436\u0434\u043E\u043C\u0443 \u0440\u0435\u0431\u0451\u043D\u043A\u0443 \u043C\u0430\u043A\u0441\u0438\u043C\u0443\u043C \u0432\u043D\u0438\u043C\u0430\u043D\u0438\u044F \u043F\u0435\u0434\u0430\u0433\u043E\u0433\u0430.",
  "Teacher": "\u0413\u0430\u0432\u0440\u0438\u043B\u043E\u0432\u0430\u00A0\u0422\u0430\u0442\u044C\u044F\u043D\u0430",
  "AgeGroup": "2 \u0433\u043E\u0434\u0430 - 14 \u043B\u0435\u0442",
  "LearnSkills": "\u0421\u0435\u043D\u0441\u043E\u0440\u043D\u043E\u043C\u0443 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044E\n\n\u0418\u0437\u043E\u0431\u0440\u0430\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0439 \u0434\u0435\u044F\u0442\u0435\u043B\u044C\u043D\u043E\u0441\u0442\u0438\n\n\u0420\u0430\u0437\u0432\u0438\u0442\u0438\u044E \u043C\u0435\u043B\u043A\u043E\u0439 \u043C\u043E\u0442\u043E\u0440\u0438\u043A\u0438\n\n\u0422\u0432\u043E\u0440\u0447\u0435\u0441\u0442\u0432\u0443",

{
  "Id": "369a9d23-e04f-4df6-bef0-c2e8405ef477",
  "Title": "\u041C\u043E\u0434\u0435\u043B\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u0435 \u0438 \u043F\u043E\u0448\u0438\u0432",
  "Description": "\u0421\u0442\u0443\u0434\u0438\u044F \u0022\u0414\u0438\u0437\u0430\u0439\u043D \u043A\u043E\u0441\u0442\u044E\u043C\u0430\u0022 \u043F\u043E\u0434 \u0440\u0443\u043A\u043E\u0432\u043E\u0434\u0441\u0442\u0432\u043E\u043C \u041F\u0443\u043B\u044F\u0435\u0432\u043E\u0439 \u041E\u043A\u0441\u0430\u043D\u044B \u0412\u0430\u0441\u0438\u043B\u044C\u0435\u0432\u043D\u044B \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442 \u0441 2023 \u0433\u043E\u0434\u0430. \u041D\u0430 \u0437\u0430\u043D\u044F\u0442\u0438\u044F \u0432 \u0441\u0442\u0443\u0434\u0438\u0438 \u0443\u0447\u0430\u0441\u0442\u043D\u0438\u043A\u043E\u0432 \u0437\u043D\u0430\u043A\u043E\u043C\u044F\u0442 \u0441 fashion-\u0438\u043D\u0434\u0443\u0441\u0442\u0440\u0438\u0435\u0439, \u0443\u0447\u0430\u0442 \u043F\u0440\u0438\u0434\u0443\u043C\u044B\u0432\u0430\u0442\u044C \u043E\u0440\u0438\u0433\u0438\u043D\u0430\u043B\u044C\u043D\u044B\u0435 \u043C\u043E\u0434\u0435\u043B\u0438 \u0438 \u0441\u043E\u0437\u0434\u0430\u0432\u0430\u0442\u044C \u044D\u0441\u043A\u0438\u0437\u044B \u0430 \u0442\u0430\u043A\u0436\u0435 \u0448\u0438\u0442\u044C \u043F\u043E \u044D\u0442\u0438\u043C \u044D\u0441\u043A\u0438\u0437\u0430\u043C \u043E\u0434\u0435\u0436\u0434\u0443.\u2028\u2028\u0417\u0434\u0435\u0441\u044C, \u0432 \u043E\u043A\u0440\u0443\u0436\u0435\u043D\u0438\u0438 \u0432\u0434\u043E\u0445\u043D\u043E\u0432\u043B\u044F\u044E\u0449\u0435\u0439 \u0430\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u044B \u0438 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u043E\u0433\u043E \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u0447\u0435\u0441\u0442\u0432\u0430, \u043A\u0430\u0436\u0434\u044B\u0439 \u0443\u0447\u0430\u0441\u0442\u043D\u0438\u043A \u043C\u043E\u0436\u0435\u0442 \u0440\u0430\u0441\u043A\u0440\u044B\u0442\u044C \u0441\u0432\u043E\u0439 \u043F\u043E\u0442\u0435\u043D\u0446\u0438\u0430\u043B \u0438 \u0441\u043E\u0437\u0434\u0430\u0442\u044C \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0438\u0435 \u043F\u0440\u043E\u0438\u0437\u0432\u0435\u0434\u0435\u043D\u0438\u044F \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u0430.\u2028\u2028\u0412 \u0441\u0442\u0443\u0434\u0438\u0438 \u0440\u0430\u0431\u043E\u0442\u0430\u044E\u0442 \u0441 \u0440\u0430\u0437\u043D\u044B\u043C\u0438 \u043C\u0430\u0442\u0435\u0440\u0438\u0430\u043B\u0430\u043C\u0438, \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0438\u0440\u0443\u044E\u0442 \u0441 \u0446\u0432\u0435\u0442\u0430\u043C\u0438 \u0438 \u0444\u043E\u0440\u043C\u0430\u043C\u0438, \u0438, \u043A\u043E\u043D\u0435\u0447\u043D\u043E \u0436\u0435, \u0441\u043E\u0437\u0434\u0430\u044E\u0442 \u0441\u043E\u0431\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435 \u0443\u043D\u0438\u043A\u0430\u043B\u044C\u043D\u044B\u0435 \u043C\u043E\u0434\u0435\u043B\u0438 \u043E\u0434\u0435\u0436\u0434\u044B. \u0414\u043B\u044F \u0434\u0435\u0442\u0435\u0439 \u043E\u0442 10 \u043B\u0435\u0442 \u0438 \u0432\u0437\u0440\u043E\u0441\u043B\u044B\u0445.",
  "Teacher": "\u041B\u0430\u0442\u044B\u043D\u0446\u0435\u0432\u0430 \u041B\u044E\u0434\u043C\u0438\u043B\u0430",
  "AgeGroup": "8 \u043B\u0435\u0442 - 50 \u043B\u0435\u0442",
  "LearnSkills": "\u0414\u0438\u0437\u0430\u0439\u043D\u0443 \u043E\u0434\u0435\u0436\u0434\u044B\n\n\u0423\u0437\u043D\u0430\u0435\u0442\u0435, \u0447\u0442\u043E \u0442\u0430\u043A\u043E\u0435 \u0441\u0442\u0438\u043B\u044C\n\n\u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\n\n\u0421\u043E\u0437\u0434\u0430\u043D\u0438\u0435 \u0430\u0432\u0442\u043E\u0440\u0441\u043A\u043E\u0433\u043E \u043A\u043E\u0441\u0442\u044E\u043C\u0430",

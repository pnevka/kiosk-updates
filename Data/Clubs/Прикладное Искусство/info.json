{
  "Id": "f62c33b8-a64a-43a4-9f48-ef9ff196cc1c",
  "Title": "\u041F\u0440\u0438\u043A\u043B\u0430\u0434\u043D\u043E\u0435 \u0418\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E",
  "Description": "\u0417\u0430\u043D\u044F\u0442\u0438\u044F \u043A\u043B\u0443\u0431\u043D\u043E\u0433\u043E \u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u043D\u0438\u044F \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u0442 \u041C\u0438\u043D\u0430\u043A\u043E\u0432\u0430 \u0415\u043A\u0430\u0442\u0435\u0440\u0438\u043D\u0430 \u0410\u043D\u0430\u0442\u043E\u043B\u044C\u0435\u0432\u043D\u0430 . \u041F\u0440\u0438 \u0440\u0435\u0430\u043B\u0438\u0437\u0430\u0446\u0438\u0438 \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u043A\u043E\u0433\u043E \u0437\u0430\u043C\u044B\u0441\u043B\u0430 \u0437\u0430\u043D\u044F\u0442\u0438\u044F \u0434\u043B\u044F \u043A\u0430\u0436\u0434\u043E\u0433\u043E \u0440\u0435\u0431\u0435\u043D\u043A\u0430 \u0440\u0435\u0433\u0443\u043B\u0438\u0440\u0443\u044E\u0442\u0441\u044F \u0438\u043D\u0434\u0438\u0432\u0438\u0434\u0443\u0430\u043B\u044C\u043D\u043E \u0432 \u0437\u0430\u0432\u0438\u0441\u0438\u043C\u043E\u0441\u0442\u0438 \u043E\u0442 \u043D\u0430\u0432\u044B\u043A\u043E\u0432 \u0438 \u0443\u043C\u0435\u043D\u0438\u0439. \u0424\u043E\u0440\u043C\u044B \u043F\u0440\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u044F \u0437\u0430\u043D\u044F\u0442\u0438\u0439 \u0440\u0430\u0437\u043B\u0438\u0447\u043D\u044B.\u2028\u2028\u041F\u0440\u0435\u0434\u0443\u0441\u043C\u043E\u0442\u0440\u0435\u043D\u044B \u043A\u0430\u043A \u0442\u0435\u043E\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435 - \u0440\u0430\u0441\u0441\u043A\u0430\u0437 \u043F\u0440\u0435\u043F\u043E\u0434\u0430\u0432\u0430\u0442\u0435\u043B\u044F, \u0431\u0435\u0441\u0435\u0434\u0430 \u0441 \u0434\u0435\u0442\u044C\u043C\u0438, \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u044B \u0434\u0435\u0442\u0435\u0439, \u043F\u043E\u043A\u0430\u0437 \u0432\u043E\u0441\u043F\u0438\u0442\u0430\u0442\u0435\u043B\u0435\u043C \u0441\u043F\u043E\u0441\u043E\u0431\u0430 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F,- \u0442\u0430\u043A \u0438 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438\u0435 \u0437\u0430\u043D\u044F\u0442\u0438\u044F: \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u043A\u0430 \u0438 \u043F\u0440\u043E\u0432\u0435\u0434\u0435\u043D\u0438\u0435 \u0432\u044B\u0441\u0442\u0430\u0432\u043E\u043A \u0434\u0435\u0442\u0441\u043A\u0438\u0445 \u0438 \u0432\u0437\u0440\u043E\u0441\u043B\u044B\u0445 \u0440\u0430\u0431\u043E\u0442, \u043D\u0435\u043F\u043E\u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0435\u043D\u043D\u043E\u0435 \u0432\u044B\u0448\u0438\u0432\u0430\u043D\u0438\u0435 \u0438\u0437\u0434\u0435\u043B\u0438\u0439, \u043E\u0431\u0441\u0443\u0436\u0434\u0435\u043D\u0438\u0435 \u0438 \u0432\u044B\u0431\u043E\u0440 \u0440\u0438\u0441\u0443\u043D\u043A\u0430 \u0434\u043B\u044F \u0432\u044B\u0448\u0438\u0432\u043A\u0438.",
  "Teacher": "\u041C\u0438\u043D\u0430\u043A\u043E\u0432\u0430 \u0415\u043A\u0430\u0442\u0435\u0440\u0438\u043D\u0430",
  "AgeGroup": "7 \u043B\u0435\u0442 - 99 \u043B\u0435\u0442",
  "LearnSkills": "\u0412\u043B\u0430\u0434\u0435\u043D\u0438\u044E \u043E\u0441\u043D\u043E\u0432\u043D\u044B\u043C\u0438 \u043F\u0440\u0438\u0435\u043C\u0430\u043C\u0438 \u0440\u0430\u0431\u043E\u0442\u044B \u0432 \u0442\u0435\u0445\u043D\u0438\u043A\u0435 \u0432\u044B\u0448\u0438\u0432\u043A\u0430 \u043A\u0440\u0435\u0441\u0442\u043E\u043C.\n\n\u041E\u0441\u0432\u0430\u0438\u0432\u0430\u0442\u044C \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0435 \u0442\u0440\u0443\u0434\u043E\u0432\u044B\u0435 \u0443\u043C\u0435\u043D\u0438\u044F \u0438 \u0441\u043F\u043E\u0441\u043E\u0431\u044B \u0441\u0430\u043C\u043E\u043A\u043E\u043D\u0442\u0440\u043E\u043B\u044F \u043F\u0440\u0438 \u0440\u0430\u0431\u043E\u0442\u0435 \u0441 \u0442\u043A\u0430\u043D\u044C\u044E\n\n\u0420\u0430\u0437\u0432\u0438\u0432\u0430\u0442\u044C \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u043A\u0443\u044E \u0430\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u044C, \u043C\u0435\u043B\u043A\u0443\u044E \u043C\u043E\u0442\u043E\u0440\u0438\u043A\u0443 \u0440\u0443\u043A",

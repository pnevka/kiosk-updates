{
  "Id": "213630e7-8857-4025-bf3e-ef9ba0c63cb3",
  "Title": "\u041D\u0430\u0440\u043E\u0434\u043D\u044B\u0439 \u0445\u043E\u0440",
  "Description": "\u0425\u043E\u0440 \u0022\u0412\u0435\u0441\u043D\u0430\u0022 \u0434\u043B\u044F \u0432\u0437\u0440\u043E\u0441\u043B\u044B\u0445 \u043E\u0442 30 \u043B\u0435\u0442 \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u044F\u0435\u0442 \u0432 \u0441\u0432\u043E\u0451\u043C \u043A\u043E\u043B\u043B\u0435\u043A\u0442\u0438\u0432\u0435 \u0432\u0441\u0435\u0445, \u043A\u0442\u043E \u043C\u0435\u0447\u0442\u0430\u0435\u0442 \u043F\u0435\u0442\u044C.\u2028\u2028\u0420\u0443\u043A\u043E\u0432\u043E\u0434\u0438\u0442\u0435\u043B\u044C \u0445\u043E\u0440\u0430 \u0412\u043E\u0440\u043E\u0442\u043D\u0438\u043A\u043E\u0432\u0430 \u041C\u0430\u0440\u0438\u0430\u043D\u043D\u0430 \u041D\u0438\u043A\u043E\u043B\u0430\u0435\u0432\u043D\u0430 - \u043F\u0435\u0434\u0430\u0433\u043E\u0433 \u0441 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u0430\u043D\u0438\u0435\u043C \u043F\u043E \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u043E\u0441\u0442\u0438 \u0022\u0422\u0435\u0430\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0435 \u0438\u0441\u043A\u0443\u0441\u0441\u0442\u0432\u043E\u0022 \u0438 \u0022\u0410\u043A\u0430\u0434\u0435\u043C\u0438\u0447\u0435\u0441\u043A\u0438\u0439 \u0432\u043E\u043A\u0430\u043B\u0022 \u043F\u043E\u043C\u043E\u0433\u0430\u0435\u0442 \u0443\u0447\u0430\u0441\u0442\u043D\u0438\u043A\u0430\u043C \u0440\u0430\u0441\u043A\u0440\u044B\u0442\u044C \u0441\u0432\u043E\u0439 \u0442\u0432\u043E\u0440\u0447\u0435\u0441\u043A\u0438\u0439 \u043F\u043E\u0442\u0435\u043D\u0446\u0438\u0430\u043B.\u2028\u2028\u0420\u0435\u043F\u0435\u0442\u0438\u0446\u0438\u0438 \u043F\u0440\u043E\u0445\u043E\u0434\u044F\u0442 \u0432 \u0443\u044E\u0442\u043D\u043E\u0439, \u0434\u0440\u0443\u0436\u0435\u0441\u043A\u043E\u0439 \u0430\u0442\u043C\u043E\u0441\u0444\u0435\u0440\u0435, \u0430 \u0432 \u0440\u0435\u043F\u0435\u0440\u0442\u0443\u0430\u0440\u0435 \u043A\u043E\u043B\u043B\u0435\u043A\u0442\u0438\u0432\u0430 \u0445\u0438\u0442\u044B \u044D\u0441\u0442\u0440\u0430\u0434\u044B, \u043B\u044E\u0431\u0438\u043C\u044B\u0435 \u0438 \u0437\u043D\u0430\u043A\u043E\u043C\u044B\u0435 \u0432\u0441\u0435\u043C.\u2028\u2028\u0425\u043E\u0440 \u0441\u043E\u0437\u0434\u0430\u043D \u0432 \u0440\u0430\u043C\u043A\u0430\u0445 \u043F\u0440\u043E\u0435\u043A\u0442\u0430 \u0022\u0410\u043A\u0442\u0438\u0432\u043D\u043E\u0435 \u0434\u043E\u043B\u0433\u043E\u043B\u0435\u0442\u0438\u0435\u0022. \u0420\u0435\u043F\u0435\u0440\u0442\u0443\u0430\u0440 \u0445\u043E\u0440\u0430 \u043E\u0442 \u043D\u0430\u0440\u043E\u0434\u043D\u043E\u0433\u043E \u0434\u043E \u0441\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0433\u043E, \u043B\u044E\u0431\u0438\u043C\u044B\u0435 \u0445\u0438\u0442\u044B \u044D\u0441\u0442\u0440\u0430\u0434\u044B \u0438 \u043C\u043D\u043E\u0433\u043E \u0434\u0440\u0443\u0433\u043E\u0435.",
  "Teacher": "\u0412\u043E\u0440\u043E\u0442\u043D\u0438\u043A\u043E\u0432\u0430 \u041C\u0430\u0440\u0438\u0430\u043D\u043D\u0430",
  "AgeGroup": "25 \u043B\u0435\u0442 - 80 \u043B\u0435\u0442",
  "LearnSkills": "\u041F\u0435\u0442\u044C \u0432\u043C\u0435\u0441\u0442\u0435\n\n\u041F\u0435\u0442\u044C \u043E\u0434\u043D\u043E\u0433\u043E\u043B\u043E\u0441\u0438\u0435\n\n\u041F\u0435\u0442\u044C \u043C\u043D\u043E\u0433\u043E\u0433\u043E\u043B\u043E\u0441\u0438\u0435\n\n\u041F\u0435\u0442\u044C \u0430 \u043A\u0430\u043F\u0435\u043B\u043B\u0430",
